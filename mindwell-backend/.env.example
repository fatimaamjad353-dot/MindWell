PORT=3000
HOST=0.0.0.0

# Required for signup/login and all saved app data.
MONGO_URI=mongodb://127.0.0.1:27017/mindwell

# Required for JWT login tokens.
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Optional services.
PYTHON_AI_URL=http://localhost:5001
AI_SERVICE_URL=http://localhost:5010
STRIPE_SECRET_KEY=
